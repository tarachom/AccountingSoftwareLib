<?xml version="1.0" encoding="UTF-8"?>
<!--
Базовий основний інтерфейс для сторінки елементу довідника
-->
<interface>
  <!-- Основний вертикальний бокс -->
  <object class="GtkBox" id="MainBox">
    <property name="orientation">vertical</property>
    <property name="hexpand">1</property>
    <property name="vexpand">1</property>

    <!-- Горизонтальна панель -->
    <child>
      <object class="GtkPaned" id="Paned">
        <property name="orientation">horizontal</property>
        <property name="hexpand">1</property>
        <property name="position">500</property>
        
        <!-- Перший child (Ліва панель) -->
        <child>
          <object class="GtkBox" id="TopStartBox">
            <property name="orientation">vertical</property>
          </object>
        </child>

        <!-- Другий child (Права панель) -->
        <child>
          <object class="GtkBox" id="TopEndBox">
            <property name="orientation">vertical</property>
          </object>
        </child>

        <property name="shrink-start-child">false</property>
        <property name="shrink-end-child">false</property>
      </object>
    </child>

  </object>
</interface>